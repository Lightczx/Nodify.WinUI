<UserControl
    x:Class="Nodify.WinUI.Experimental.View.NodeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="using:Nodify.WinUI.Experimental.View"
    mc:Ignorable="d"
    Width="{Binding Width}"
    Height="{Binding Height}"
    PointerPressed="NodeControl_PointerPressed"
    PointerMoved="NodeControl_PointerMoved"
    PointerReleased="NodeControl_PointerReleased">

    <UserControl.Resources>
        <Style x:Key="PortItemsControlStyle" TargetType="ItemsControl">
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <view:PortControl Margin="4,2"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="8">
            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>
        </Border>

        <!-- Selected State Border -->
        <Border
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            BorderThickness="3"
            CornerRadius="8"
            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" 
                  Background="{ThemeResource AccentFillColorDefaultBrush}"
                  CornerRadius="6,6,0,0"
                  Padding="8,4"
                  x:Name="TitleBar">
                <TextBlock 
                    Text="{Binding Title}"
                    FontWeight="SemiBold"
                    Foreground="White"
                    VerticalAlignment="Center"/>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1" Padding="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Input Ports -->
                <ItemsControl 
                    Grid.Column="0"
                    ItemsSource="{Binding InputPorts}"
                    Style="{StaticResource PortItemsControlStyle}"
                    VerticalAlignment="Center"
                    x:Name="InputPortsControl"/>

                <!-- Content -->
                <TextBlock
                    Grid.Column="1"
                    Text="{Binding Content}"
                    TextWrapping="Wrap"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="8,0"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <!-- Output Ports -->
                <ItemsControl 
                    Grid.Column="2"
                    ItemsSource="{Binding OutputPorts}"
                    Style="{StaticResource PortItemsControlStyle}"
                    VerticalAlignment="Center"
                    x:Name="OutputPortsControl"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
