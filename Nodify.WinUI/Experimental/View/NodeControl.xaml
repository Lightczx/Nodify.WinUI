<UserControl
    x:Class="Nodify.WinUI.Experimental.View.NodeControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Nodify.WinUI.Experimental.Converters"
    xmlns:cwc="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="using:Nodify.WinUI.Experimental.View"
    PointerMoved="OnPointerMoved"
    PointerPressed="OnPointerPressed"
    PointerReleased="OnPointerReleased"
    mc:Ignorable="d">

    <UserControl.Resources>
        <cwc:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PortItemsControlStyle" TargetType="ItemsControl">
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <view:PortControl Margin="4,2" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="8">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
        </Border>

        <!--  Selected State Border  -->
        <Border
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            BorderThickness="3"
            CornerRadius="8"
            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />

        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Title Bar  -->
            <Grid
                x:Name="TitleBar"
                Grid.Row="0"
                Padding="8,4"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="6,6,0,0">
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="{Binding Title}" />
            </Grid>

            <!--  Content Area  -->
            <Grid Grid.Row="1" Padding="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Input Ports  -->
                <ItemsControl
                    x:Name="InputPortsControl"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding InputPorts}"
                    Style="{StaticResource PortItemsControlStyle}" />

                <!--  Content  -->
                <TextBlock
                    Grid.Column="1"
                    Margin="8,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding Content}"
                    TextWrapping="Wrap" />

                <!--  Output Ports  -->
                <ItemsControl
                    x:Name="OutputPortsControl"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding OutputPorts}"
                    Style="{StaticResource PortItemsControlStyle}" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
