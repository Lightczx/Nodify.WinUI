<UserControl
    x:Class="Nodify.WinUI.Experimental.View.PropertiesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Nodify.WinUI.Experimental.Converters"
    xmlns:cwc="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:EmptyObjectToVisibilityConverter x:Key="EmptyObjectToVisibilityConverter" />
        <converters:EmptyObjectToVisibilityInverseConverter x:Key="EmptyObjectToVisibilityInverseConverter" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource LayerFillColorDefaultBrush}">
        <ScrollViewer>
            <StackPanel
                Padding="16"
                Spacing="16"
                Visibility="{Binding SelectedNode, Converter={StaticResource EmptyObjectToVisibilityConverter}}">

                <!--  Header  -->
                <TextBlock
                    Margin="0,0,0,8"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="节点属性" />

                <!--  Node Title  -->
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="标题" />
                    <TextBox PlaceholderText="输入节点标题..." Text="{Binding SelectedNode.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!--  Node Content  -->
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="内容" />
                    <TextBox
                        MinHeight="60"
                        AcceptsReturn="True"
                        PlaceholderText="输入节点内容..."
                        Text="{Binding SelectedNode.Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!--  Node Position  -->
                <StackPanel Spacing="4">
                    <TextBlock FontWeight="SemiBold" Text="位置" />
                    <Grid
                        Padding="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="X" />
                            <TextBlock Text="{Binding SelectedNode.PositionXText}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock
                                FontSize="11"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Y" />
                            <TextBlock Text="{Binding SelectedNode.PositionYText}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!--  Input Ports Section  -->
                <StackPanel Spacing="8">
                    <Grid>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="输入端口" />
                        <Button
                            Width="32"
                            Height="32"
                            HorizontalAlignment="Right"
                            Command="{Binding SelectedNode.AddInputPortCommand}"
                            Content="+"
                            ToolTipService.ToolTip="添加输入端口" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding SelectedNode.InputPorts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    Margin="0,4"
                                    Padding="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        Grid.Column="0"
                                        Margin="0,0,8,0"
                                        PlaceholderText="端口名称..."
                                        Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <Button
                                        Grid.Column="1"
                                        Width="32"
                                        Height="32"
                                        Command="{Binding DataContext.SelectedNode.RemovePortCommand, ElementName=RootGrid}"
                                        CommandParameter="{Binding}"
                                        Content="&#xE74D;"
                                        FontFamily="Segoe MDL2 Assets"
                                        ToolTipService.ToolTip="删除端口" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!--  Output Ports Section  -->
                <StackPanel Spacing="8">
                    <Grid>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Text="输出端口" />
                        <Button
                            Width="32"
                            Height="32"
                            HorizontalAlignment="Right"
                            Command="{Binding SelectedNode.AddOutputPortCommand}"
                            Content="+"
                            ToolTipService.ToolTip="添加输出端口" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding SelectedNode.OutputPorts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid
                                    Margin="0,4"
                                    Padding="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox
                                        Grid.Column="0"
                                        Margin="0,0,8,0"
                                        PlaceholderText="端口名称..."
                                        Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <Button
                                        Grid.Column="1"
                                        Width="32"
                                        Height="32"
                                        Command="{Binding DataContext.SelectedNode.RemovePortCommand, ElementName=RootGrid}"
                                        CommandParameter="{Binding}"
                                        Content="&#xE74D;"
                                        FontFamily="Segoe MDL2 Assets"
                                        ToolTipService.ToolTip="删除端口" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!--  Node Actions  -->
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Text="操作" />
                    <Button
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource SystemFillColorCriticalBrush}"
                        Command="{Binding DeleteSelectedNodeCommand}"
                        Content="删除节点" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!--  Empty State  -->
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            Visibility="{Binding SelectedNode, Converter={StaticResource EmptyObjectToVisibilityInverseConverter}}">
            <FontIcon
                FontSize="48"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Glyph="&#xE946;" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="未选中节点" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="点击节点查看属性" />
        </StackPanel>
    </Grid>
</UserControl>
