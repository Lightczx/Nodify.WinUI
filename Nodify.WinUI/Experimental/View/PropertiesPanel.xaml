<UserControl
    x:Class="Nodify.WinUI.Experimental.View.PropertiesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Nodify.WinUI.Experimental.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource LayerFillColorDefaultBrush}">
        <ScrollViewer>
            <StackPanel 
                Padding="16"
                Spacing="16"
                Visibility="{Binding SelectedNode, Converter={StaticResource BoolToVisibilityConverter}}">

                <!-- Header -->
                <TextBlock 
                    Text="节点属性" 
                    Style="{StaticResource TitleTextBlockStyle}"
                    Margin="0,0,0,8"/>

                <!-- Node Title -->
                <StackPanel Spacing="4">
                    <TextBlock Text="标题" FontWeight="SemiBold"/>
                    <TextBox 
                        Text="{Binding SelectedNode.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="输入节点标题..."/>
                </StackPanel>

                <!-- Node Content -->
                <StackPanel Spacing="4">
                    <TextBlock Text="内容" FontWeight="SemiBold"/>
                    <TextBox 
                        Text="{Binding SelectedNode.Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="输入节点内容..."
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        MinHeight="60"/>
                </StackPanel>

                <!-- Input Ports Section -->
                <StackPanel Spacing="8">
                    <Grid>
                        <TextBlock Text="输入端口" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button 
                            Content="+" 
                            Command="{Binding SelectedNode.AddInputPortCommand}"
                            HorizontalAlignment="Right"
                            Width="32"
                            Height="32"
                            ToolTipService.ToolTip="添加输入端口"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding SelectedNode.InputPorts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid 
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    Padding="8"
                                    CornerRadius="4"
                                    Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox 
                                        Grid.Column="0"
                                        Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="端口名称..."
                                        Margin="0,0,8,0"/>

                                    <Button 
                                        Grid.Column="1"
                                        Content="&#xE74D;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Command="{Binding DataContext.SelectedNode.RemovePortCommand, ElementName=RootGrid}"
                                        CommandParameter="{Binding}"
                                        Width="32"
                                        Height="32"
                                        ToolTipService.ToolTip="删除端口"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Output Ports Section -->
                <StackPanel Spacing="8">
                    <Grid>
                        <TextBlock Text="输出端口" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button 
                            Content="+" 
                            Command="{Binding SelectedNode.AddOutputPortCommand}"
                            HorizontalAlignment="Right"
                            Width="32"
                            Height="32"
                            ToolTipService.ToolTip="添加输出端口"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding SelectedNode.OutputPorts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid 
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    Padding="8"
                                    CornerRadius="4"
                                    Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox 
                                        Grid.Column="0"
                                        Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="端口名称..."
                                        Margin="0,0,8,0"/>

                                    <Button 
                                        Grid.Column="1"
                                        Content="&#xE74D;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Command="{Binding DataContext.SelectedNode.RemovePortCommand, ElementName=RootGrid}"
                                        CommandParameter="{Binding}"
                                        Width="32"
                                        Height="32"
                                        ToolTipService.ToolTip="删除端口"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Node Actions -->
                <StackPanel Spacing="8">
                    <TextBlock Text="操作" FontWeight="SemiBold"/>
                    <Button 
                        Content="删除节点"
                        Command="{Binding DeleteSelectedNodeCommand}"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource SystemFillColorCriticalBrush}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Empty State -->
        <StackPanel 
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            Visibility="{Binding SelectedNode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <FontIcon 
                Glyph="&#xE946;"
                FontSize="48"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            <TextBlock 
                Text="未选中节点"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                HorizontalAlignment="Center"/>
            <TextBlock 
                Text="点击节点查看属性"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                FontSize="12"
                HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
