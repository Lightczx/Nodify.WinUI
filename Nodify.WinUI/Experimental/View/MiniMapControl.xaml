<UserControl
    x:Class="Nodify.WinUI.Experimental.View.MiniMapControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:Nodify.WinUI.Experimental.Converters"
    mc:Ignorable="d"
    Width="200"
    Height="150">

    <UserControl.Resources>
        <converters:PercentageConverter x:Key="PercentageConverter"/>
    </UserControl.Resources>

    <Grid>
        <Border
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="4"
            Opacity="0.9">
            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>
        </Border>

        <Canvas x:Name="MiniMapCanvas" Margin="4">
            <!-- Viewport Rectangle -->
            <Rectangle
                x:Name="ViewportRect"
                Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                StrokeThickness="2"
                Fill="{ThemeResource AccentFillColorDefaultBrush}"
                Opacity="0.3"
                PointerPressed="OnViewportRectPointerPressed"
                PointerMoved="OnViewportRectPointerMoved"
                PointerReleased="OnViewportRectPointerReleased"/>
        </Canvas>

        <!-- Zoom info -->
        <TextBlock
            Text="{Binding ViewportScale, Converter={StaticResource PercentageConverter}}"
            FontSize="10"
            Margin="8,4"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
    </Grid>
</UserControl>
