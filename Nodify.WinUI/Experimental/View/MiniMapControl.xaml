<UserControl
    x:Class="Nodify.WinUI.Experimental.View.MiniMapControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Nodify.WinUI.Experimental.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:PercentageConverter x:Key="PercentageConverter" />
    </UserControl.Resources>

    <Border
        Width="200"
        Height="150"
        Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="4">
        <Grid>
            <Canvas x:Name="MiniMapCanvas">
                <!--  Viewport Rectangle  -->
                <Rectangle
                    x:Name="ViewportRect"
                    Fill="{ThemeResource AccentFillColorDefaultBrush}"
                    Opacity="0.3"
                    PointerMoved="OnViewportRectPointerMoved"
                    PointerPressed="OnViewportRectPointerPressed"
                    PointerReleased="OnViewportRectPointerReleased"
                    Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                    StrokeThickness="2" />
            </Canvas>

            <!--  Zoom info  -->
            <TextBlock
                Margin="8,4"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding ViewportScale, Converter={StaticResource PercentageConverter}}" />
        </Grid>
    </Border>
</UserControl>
