<UserControl
    x:Class="Nodify.WinUI.Experimental.View.ConnectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    IsHitTestVisible="True"
    mc:Ignorable="d">

    <Grid>
        <Path
            x:Name="ConnectionPath"
            DoubleTapped="OnConnectionPathDoubleTapped"
            PointerEntered="OnConnectionPathPointerEntered"
            PointerExited="OnConnectionPathPointerExited"
            Stroke="{ThemeResource AccentFillColorDefaultBrush}"
            StrokeEndLineCap="Round"
            StrokeStartLineCap="Round"
            StrokeThickness="3" />

        <!--  Selected State  -->
        <Path
            x:Name="SelectionPath"
            IsHitTestVisible="False"
            Opacity="0.5"
            Stroke="{ThemeResource SystemFillColorCriticalBrush}"
            StrokeThickness="5"
            Visibility="Collapsed" />
    </Grid>
</UserControl>
