<UserControl
    x:Class="Nodify.WinUI.Experimental.View.ConnectionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    IsHitTestVisible="True">

    <Grid>
        <Path
            x:Name="ConnectionPath"
            Stroke="{ThemeResource AccentFillColorDefaultBrush}"
            StrokeThickness="3"
            StrokeStartLineCap="Round"
            StrokeEndLineCap="Round"
            PointerEntered="OnConnectionPathPointerEntered"
            PointerExited="OnConnectionPathPointerExited"
            DoubleTapped="OnConnectionPathDoubleTapped"/>

        <!-- Selected State -->
        <Path
            x:Name="SelectionPath"
            Stroke="{ThemeResource SystemFillColorCriticalBrush}"
            StrokeThickness="5"
            Opacity="0.5"
            Visibility="Collapsed"
            IsHitTestVisible="False"/>
    </Grid>
</UserControl>
