<UserControl
    x:Class="Nodify.WinUI.Experimental.View.NodeEditorCanvas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Nodify.WinUI.Experimental.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="using:Nodify.WinUI.Experimental.View"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush
            x:Key="GridLineBrush"
            Opacity="0.3"
            Color="{ThemeResource SystemBaseLowColor}" />
        <converters:PercentageConverter x:Key="PercentageConverter" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <!--  Background Grid Pattern  -->
        <Canvas x:Name="BackgroundCanvas" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Canvas.RenderTransform>
                <CompositeTransform x:Name="BackgroundTransform" />
            </Canvas.RenderTransform>
        </Canvas>

        <!--  Main Canvas with Transform  -->
        <Canvas
            x:Name="MainCanvas"
            Background="Transparent"
            DoubleTapped="OnMainCanvasDoubleTapped"
            PointerMoved="OnMainCanvasPointerMoved"
            PointerPressed="OnMainCanvasPointerPressed"
            PointerReleased="OnMainCanvasPointerReleased"
            PointerWheelChanged="OnMainCanvasPointerWheelChanged">

            <Canvas.RenderTransform>
                <CompositeTransform x:Name="CanvasTransform" />
            </Canvas.RenderTransform>

            <!--  Connections Layer  -->
            <Canvas x:Name="ConnectionsCanvas" IsHitTestVisible="True" />

            <!--  Pending Connection  -->
            <view:ConnectionControl
                x:Name="PendingConnectionControl"
                IsHitTestVisible="False"
                Visibility="Collapsed" />

            <!--  Nodes Layer  -->
            <Canvas x:Name="NodesCanvas" />
        </Canvas>

        <!--  MiniMap  -->
        <view:MiniMapControl
            x:Name="MiniMap"
            Margin="16"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom" />

        <!--  Toolbar  -->
        <StackPanel
            Margin="16"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Orientation="Horizontal"
            Spacing="8">

            <Button Click="OnAddNodeButtonClick" Content="➕ Add Node">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="N" Modifiers="Control" />
                </Button.KeyboardAccelerators>
            </Button>

            <Button Click="OnZoomInButtonClick" Content="🔍+">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Add" Modifiers="Control" />
                </Button.KeyboardAccelerators>
            </Button>

            <Button Click="OnZoomOutButtonClick" Content="🔍-">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Subtract" Modifiers="Control" />
                </Button.KeyboardAccelerators>
            </Button>

            <Button Click="OnResetViewButtonClick" Content="⟲ Reset View">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Number0" Modifiers="Control" />
                </Button.KeyboardAccelerators>
            </Button>

            <Button Click="OnSaveButtonClick" Content="💾 Save">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="S" Modifiers="Control" />
                </Button.KeyboardAccelerators>
            </Button>

            <Button Click="OnLoadButtonClick" Content="📂 Load">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="O" Modifiers="Control" />
                </Button.KeyboardAccelerators>
            </Button>
        </StackPanel>

        <!--  Status Bar  -->
        <Border
            Height="32"
            VerticalAlignment="Bottom"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel
                Margin="16,0"
                Orientation="Horizontal"
                Spacing="16">
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Nodes: " />
                    <Run Text="{Binding Nodes.Count}" />
                </TextBlock>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Connections: " />
                    <Run Text="{Binding Connections.Count}" />
                </TextBlock>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="Zoom: " />
                    <Run Text="{Binding ViewportScale, Converter={StaticResource PercentageConverter}}" />
                </TextBlock>
                <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="Pan: Middle Mouse | Zoom: Ctrl+Wheel | Connect: Drag from Port | Delete: Double-click Connection" />
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
