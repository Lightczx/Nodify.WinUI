<UserControl
    x:Class="Nodify.WinUI.Experimental.View.NodeEditorCanvas"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Nodify.WinUI.Experimental.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="using:Nodify.WinUI.Experimental.View"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush
            x:Key="GridLineBrush"
            Opacity="0.3"
            Color="{ThemeResource SystemBaseLowColor}" />
        <converters:PercentageConverter x:Key="PercentageConverter" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <Grid.Clip>
            <RectangleGeometry x:Name="RootGridClip" />
        </Grid.Clip>
        <!--  Main Canvas with Transform  -->
        <Canvas
            x:Name="MainCanvas"
            Width="{x:Bind ViewModel.CanvasWidth, Mode=OneWay}"
            Height="{x:Bind ViewModel.CanvasHeight, Mode=OneWay}"
            Background="#80000000"
            DoubleTapped="OnMainCanvasDoubleTapped"
            PointerMoved="OnMainCanvasPointerMoved"
            PointerPressed="OnMainCanvasPointerPressed"
            PointerReleased="OnMainCanvasPointerReleased"
            PointerWheelChanged="OnMainCanvasPointerWheelChanged">

            <Canvas.RenderTransform>
                <CompositeTransform x:Name="CanvasTransform" />
            </Canvas.RenderTransform>

            <!--  Connections Layer  -->
            <Canvas x:Name="ConnectionsCanvas" IsHitTestVisible="True" />

            <!--  Pending Connection  -->
            <view:ConnectionControl
                x:Name="PendingConnectionControl"
                IsHitTestVisible="False"
                Visibility="Collapsed" />

            <!--  Nodes Layer  -->
            <Canvas x:Name="NodesCanvas" />
        </Canvas>

        <!--  MiniMap  -->
        <view:MiniMapControl
            x:Name="MiniMap"
            Margin="16"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom" />
    </Grid>
</UserControl>
