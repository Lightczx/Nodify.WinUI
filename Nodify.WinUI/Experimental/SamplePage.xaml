<Page
    x:Class="Nodify.WinUI.Experimental.SamplePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="using:Nodify.WinUI.Experimental.View"
    xmlns:converters="using:Nodify.WinUI.Experimental.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:EmptyObjectToBoolConverter x:Key="EmptyObjectToBoolConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Grid Grid.Row="0"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              Padding="16,12"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <TextBlock
                Text="Node Editor - Experimental"
                Style="{ThemeResource TitleTextBlockStyle}"/>
        </Grid>

        <!-- Toolbar -->
        <Grid Grid.Row="1"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              Padding="12,8"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Add Node"
                        Command="{x:Bind NodeEditor.ViewModel.AddNodeCommand}"
                        ToolTipService.ToolTip="Double-click canvas to add node">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="N" Modifiers="Control"/>
                    </Button.KeyboardAccelerators>
                </Button>

                <Button Content="Delete Selected"
                        Command="{x:Bind NodeEditor.ViewModel.DeleteSelectedNodeCommand}"
                        IsEnabled="{x:Bind NodeEditor.ViewModel.SelectedNode, Mode=OneWay, Converter={StaticResource EmptyObjectToBoolConverter}}"
                        ToolTipService.ToolTip="Delete selected node (Del)">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Delete"/>
                    </Button.KeyboardAccelerators>
                </Button>

                <Rectangle Width="1"
                          Fill="{ThemeResource ControlStrokeColorDefaultBrush}"
                          Margin="4,0"/>

                <TextBlock Text="Zoom:"
                          VerticalAlignment="Center"
                          Margin="4,0"/>
                <TextBlock Text="{x:Bind NodeEditor.ViewModel.ViewportScale, Mode=OneWay}"
                          VerticalAlignment="Center"
                          MinWidth="40"/>

                <Button Content="Reset Zoom"
                        Click="OnResetZoomClick"
                        ToolTipService.ToolTip="Reset zoom to 100% (Ctrl+0)">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Number0" Modifiers="Control"/>
                    </Button.KeyboardAccelerators>
                </Button>

                <Rectangle Width="1"
                          Fill="{ThemeResource ControlStrokeColorDefaultBrush}"
                          Margin="4,0"/>

                <TextBlock Text="{x:Bind NodeEditor.ViewModel.Nodes.Count, Mode=OneWay}"
                          VerticalAlignment="Center"/>
                <TextBlock Text="Nodes"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"/>

                <TextBlock Text="{x:Bind NodeEditor.ViewModel.Connections.Count, Mode=OneWay}"
                          VerticalAlignment="Center"/>
                <TextBlock Text="Connections"
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Main Content with Properties Panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Node Editor -->
            <view:NodeEditorCanvas
                x:Name="NodeEditor"
                Grid.Column="0"/>

            <!-- Splitter -->
            <Rectangle Grid.Column="1"
                      Width="1"
                      Fill="{ThemeResource ControlStrokeColorDefaultBrush}"/>

            <!-- Properties Panel -->
            <view:PropertiesPanel
                Grid.Column="2"
                DataContext="{x:Bind NodeEditor.ViewModel, Mode=OneWay}"/>
        </Grid>
    </Grid>
</Page>
